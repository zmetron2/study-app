{
  "name": "study",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "npx vercel build && npx @cloudflare/next-on-pages --skip-build",
    "pages:dev": "npx wrangler pages dev .vercel/output --proxy http://127.0.0.1:3000",
    "pages:dev:cf": "npx wrangler pages dev .vercel/output --proxy http://127.0.0.1:3000",
    "pages:deploy": "npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output"
  },
  "dependencies": {
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "agora-rtc-sdk-ng": "^4.24.3",
    "lucide-react": "^0.473.0",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vercel": "^53.2.0",
    "wrangler": "^4.86.0"
  }
}
